{
  "ListSelector": "#mosaic-provider-jobcards",
  "NextPageSelector": "a[data-testid='pagination-page-next']",
  "ItemConfig": {
    "ItemSelector": ".job_seen_beacon",
    "ExclusionRules": [
      {
        "Selector": ".advertisement",
        "MustExist": true
      },
      {
        "Selector": "h2.jobTitle span[title]",
        "MustExist": false
      }
    ],
    "TitleSelector": "h2.jobTitle span[title]",
    "DetailSelector": "a.jcs-JobTitle",
    "JobKeyAttribute": "data-jk",
    "DetailUrlTemplate": "https://be.indeed.com/viewjob?jk={0}",
    "DetailConfig": {
      "MainSelector": "#jobDescriptionText",           
      "FieldSelectors": {
        "JobDescription": "#jobDescriptionText",
        "CompanyName": "[data-testid='inlineHeader-companyName']",
        "Location": "[data-testid='inlineHeader-companyLocation']",
        "Salary": "#salaryInfoAndJobType",
        "ContractType": "#salaryInfoAndJobType",
        "PostedDateRaw": ".jobsearch-JobMetadataFooter",
        "ApplyLink": "button[aria-label='Postuler maintenant']",
        "Benefits": "[data-testid='jobsearch-JobDescriptionSection-sectionItem']"
      }
    }
  }
}